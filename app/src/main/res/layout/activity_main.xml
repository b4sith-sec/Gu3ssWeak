<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚡ Gu3ssWeak" android:textSize="32sp" android:textStyle="bold"
            android:textColor="#FF3B30" android:layout_gravity="center"
            android:paddingTop="24dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Vulnerable Android Lab" android:textSize="13sp"
            android:textColor="#888888" android:layout_gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="19 Vulnerabilities · OWASP Mobile Top 10"
            android:textSize="11sp" android:textColor="#FF3B30"
            android:layout_gravity="center" android:layout_marginTop="4dp" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⚠️  For authorized security research only"
            android:background="#1A1A1A" android:textColor="#FF9500"
            android:textSize="11sp" android:gravity="center"
            android:padding="10dp" android:layout_marginBottom="20dp"/>

        <!-- WEBVIEW -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● WEBVIEW LABS" android:textSize="11sp"
            android:textColor="#FF3B30" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_webview" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="🌐  WebView Exploits · WV-01 to WV-05"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="16dp"/>

        <!-- DEEPLINK -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● DEEPLINK LABS" android:textSize="11sp"
            android:textColor="#FF9500" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_deeplink" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="🔗  Deeplink Hijack · DL-01 to DL-04"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_deeplink_chain" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="⛓️  Deeplink → WebView RCE Chain"
            android:backgroundTint="#1C1C1E" android:textColor="#FF9500"
            android:textSize="13sp" android:layout_marginBottom="16dp"/>

        <!-- ADMIN -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● AUTH / ADMIN LABS" android:textSize="11sp"
            android:textColor="#30D158" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_admin" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="🔓  Admin Panel · AP-01 AP-02 AP-03"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="16dp"/>

        <!-- BROADCAST -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● BROADCAST RECEIVER LABS" android:textSize="11sp"
            android:textColor="#0A84FF" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_broadcast" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="📡  Broadcast Receiver · BR-01 BR-02 BR-03"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="16dp"/>

        <!-- SERVICE -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● SERVICE LABS" android:textSize="11sp"
            android:textColor="#BF5AF2" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_service_wipe" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="💣  Data Wipe via Service · SV-02a"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_service_exfil" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="📤  Data Exfil / SSRF · SV-02b"
            android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF"
            android:textSize="13sp" android:layout_marginBottom="20dp"/>

        <!-- ADB CHEATSHEET -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="● ADB QUICK COMMANDS" android:textSize="11sp"
            android:textColor="#888888" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="$ adb shell am broadcast -a com.vulndroid.app.SEND_TOKEN --es token FAKE&#10;$ adb shell am start -n com.vulndroid.app/.activities.AdminPanelActivity&#10;$ adb logcat | grep VulnDroid&#10;$ adb shell am startservice -n com.vulndroid.app/.services.DataSyncService --es action wipe_user_data"
            android:background="#1C1C1E" android:textColor="#30D158"
            android:fontFamily="monospace" android:textSize="10sp"
            android:padding="12dp" android:lineSpacingMultiplier="1.6"
            android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btn_submit_flag" android:layout_width="match_parent" android:layout_height="52dp" android:text="🚩  Submit Flag" android:backgroundTint="#FF3B30" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btn_scoreboard" android:layout_width="match_parent" android:layout_height="52dp" android:text="🏆  CTF Scoreboard" android:backgroundTint="#1C1C1E" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
