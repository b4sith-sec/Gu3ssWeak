<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Remember Me" android:textSize="26sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:layout_marginTop="32dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="VULN-STORE-01 - Plaintext credentials in SharedPreferences"
            android:textSize="11sp" android:textColor="#888888" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Saving credentials here writes them in plaintext to SharedPreferences, with no EncryptedSharedPreferences or Keystore-backed encryption."
            android:textSize="12sp" android:textColor="#AAAAAA"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="USERNAME" android:textSize="10sp"
            android:textColor="#888888" android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_store_username"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="username" android:textColorHint="#444444"
            android:textColor="#FFFFFF" android:textSize="14sp"
            android:background="#111111" android:padding="14dp" android:singleLine="true"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PASSWORD" android:textSize="10sp"
            android:textColor="#888888" android:letterSpacing="0.1"
            android:layout_marginTop="16dp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_store_password"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="password" android:textColorHint="#444444"
            android:textColor="#FFFFFF" android:textSize="14sp"
            android:background="#111111" android:padding="14dp"
            android:singleLine="true" android:inputType="textPassword"/>

        <Button android:id="@+id/btn_store_save"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Save with Remember Me" android:backgroundTint="#FFFFFF"
            android:textColor="#000000" android:textSize="14sp"
            android:layout_marginTop="20dp"/>

        <TextView android:id="@+id/tv_store_result"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="12sp" android:fontFamily="monospace"
            android:padding="14dp" android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="16dp" android:visibility="gone"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Exploit: adb shell run-as com.vulndroid.app cat /data/data/com.vulndroid.app/shared_prefs/login_prefs.xml"
            android:textSize="11sp" android:textColor="#555555" android:fontFamily="monospace"
            android:background="#0A0A0A" android:padding="14dp"
            android:lineSpacingMultiplier="1.5" android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>
