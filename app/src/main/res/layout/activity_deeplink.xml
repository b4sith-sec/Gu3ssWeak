<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Deeplink Lab" android:textSize="22sp" android:textStyle="bold"
        android:textColor="#E65100" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/tv_deeplink_data" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:padding="12dp"
        android:background="#FFF3E0" android:fontFamily="monospace"
        android:text="No deeplink received yet." android:lineSpacingMultiplier="1.6"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Current Token:" android:textStyle="bold" android:layout_marginTop="16dp"/>
    <TextView android:id="@+id/tv_token" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:padding="12dp"
        android:background="#FFEBEE" android:fontFamily="monospace" android:textColor="#B71C1C"/>
</LinearLayout>
