<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">
    <EditText android:id="@+id/et_url" android:layout_width="match_parent"
        android:layout_height="48dp" android:hint="Enter URL" android:padding="8dp"/>
    <Button android:id="@+id/btn_load" android:layout_width="match_parent"
        android:layout_height="48dp" android:text="Load"
        android:backgroundTint="#B71C1C" android:textColor="#FFFFFF"/>
    <WebView android:id="@+id/webview" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"/>
</LinearLayout>
